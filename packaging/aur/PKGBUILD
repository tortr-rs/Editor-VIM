# Maintainer: tortr-rs <https://github.com/tortr-rs>
pkgname=evim-editor
pkgver=1.0.0
pkgrel=1
pkgdesc="Modal CLI text editor with Vim keybindings, LSP, plugins, and 24 themes"
arch=('any')
url="https://github.com/tortr-rs/Editor-VIM"
license=('MIT')
depends=('python')
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

package() {
    cd "Editor-VIM-$pkgver"
    install -Dm755 evim.py "$pkgdir/usr/lib/evim/evim.py"
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/evim" <<'EOF'
#!/bin/sh
exec python3 /usr/lib/evim/evim.py "$@"
EOF
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
