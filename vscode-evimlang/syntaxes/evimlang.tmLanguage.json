{
  "name": "evimlang",
  "scopeName": "source.evimlang",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#command"
    },
    {
      "include": "#string"
    }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.evimlang",
          "match": "\".*$"
        }
      ]
    },
    "command": {
      "patterns": [
        {
          "name": "keyword.control.evimlang",
          "match": "\\b(set|map|python)\\b"
        },
        {
          "name": "variable.parameter.evimlang",
          "match": "\\b(number|theme|tabsize|indent_guides|show_command)\\b"
        },
        {
          "name": "constant.language.evimlang",
          "match": "\\b(normal|insert|command)\\b"
        }
      ]
    },
    "string": {
      "name": "string.quoted.double.evimlang",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.evimlang",
          "match": "\\\\."
        }
      ]
    }
  }
}